# Backend MiMedicina - Variables de entorno
# Copia este archivo a .env y completa los valores.
# Obtén las credenciales en: Firebase Console → Configuración → Cuentas de servicio → Generar clave privada

# Firebase Admin SDK (obligatorias)
FIREBASE_PROJECT_ID=mimedicinaapp
# Clave privada de la cuenta de servicio (poner entre comillas si incluye saltos de línea \n)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu_proyecto_id.iam.gserviceaccount.com

# JWT (recomendado cambiar JWT_SECRET en producción)
JWT_SECRET=tu_secret_super_seguro_aqui_cambiar_en_produccion
JWT_EXPIRES_IN=7d

# Servidor (opcionales)
PORT=3001
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# Google Calendar (opcional; para sincronizar tomas con Google Calendar)
# Mismo Client ID que en frontend (OAuth 2.0 - Aplicación web)
REACT_APP_GOOGLE_CLIENT_ID=tu_client_id.apps.googleusercontent.com
# Client Secret del mismo cliente OAuth (necesario para flujo con código y renovación automática)
GOOGLE_CALENDAR_CLIENT_SECRET=
# Debe coincidir exactamente con la URI autorizada en Google Cloud (ej. http://localhost:3000/auth/google/callback)
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/auth/google/callback
